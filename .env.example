# MBOX Viewer Configuration
# Copy this file to .env and adjust the values for your environment

# Path to the MBOX file to process and view
# This should be an absolute path to your .mbox file
MBOX_FILE_PATH=/Users/tomastrnka/Downloads/bigger_example.mbox

# Ollama server URL for embeddings
# Used for RAG (Retrieval Augmented Generation) search functionality
OLLAMA_URL=http://localhost:11434/api/embed

# Ollama embedding model to use
# Common options: nomic-embed-text, embeddinggemma, all-minilm, mxbai-embed-large
# Note: The model must produce 768-dimension embeddings (nomic-embed-text, embeddinggemma)
OLLAMA_MODEL=nomic-embed-text
